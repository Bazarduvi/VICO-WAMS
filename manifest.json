{
  "name": "WAMS - WhatsApp Media Share",
  "short_name": "WAMS",
  "description": "Obtén y comparte miniaturas de YouTube en estados de WhatsApp",
  "start_url": "/index.html",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#0a0a0f",
  "theme_color": "#00f5ff",
  "lang": "es",
  "categories": ["utilities", "social", "multimedia"],
  "icons": [
    {
      "src": "icon.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "icon.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon.png",
      "sizes": "180x180",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon.png",
      "sizes": "152x152",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon.png",
      "sizes": "144x144",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon.png",
      "sizes": "128x128",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "screenshots": [
    {
      "src": "icon.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Pantalla principal WAMS"
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+wams",
      "url": "/index.html?url=%s"
    }
  ],
  "shortcuts": [
    {
      "name": "Nueva miniatura",
      "short_name": "Nueva",
      "description": "Extrae una miniatura de YouTube",
      "url": "/index.html",
      "icons": [{ "src": "icon.png", "sizes": "96x96" }]
    },
    {
      "name": "Biblioteca",
      "short_name": "Biblioteca",
      "description": "Ver videos guardados",
      "url": "/index.html#library",
      "icons": [{ "src": "icon.png", "sizes": "96x96" }]
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "edge_side_panel": {
    "preferred_width": 400
  }
}
